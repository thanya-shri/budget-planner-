<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BudgetFlow — Personal Finance Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f14;
    --surface: #18181f;
    --surface2: #22222c;
    --border: #2e2e3d;
    --accent: #7c6af7;
    --accent2: #f97316;
    --green: #22d3a3;
    --red: #f43f5e;
    --text: #f0f0f8;
    --muted: #8888aa;
    --radius: 16px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
  
  header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-bottom: 1px solid var(--border);
    padding: 18px 32px;
    display: flex; align-items: center; justify-content: space-between;
  }
  header h1 { font-family: 'Syne', sans-serif; font-size: 1.6rem; font-weight: 800; }
  header h1 span { color: var(--accent); }
  header .month-badge {
    background: var(--surface2); border: 1px solid var(--border);
    padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; color: var(--muted);
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 28px 24px; }

  /* Summary Cards */
  .summary-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 28px; }
  .summary-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px 24px;
    position: relative; overflow: hidden;
  }
  .summary-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  }
  .summary-card.income::before { background: var(--green); }
  .summary-card.expense::before { background: var(--red); }
  .summary-card.balance::before { background: var(--accent); }
  .summary-card .label { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px; }
  .summary-card .amount { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; }
  .summary-card.income .amount { color: var(--green); }
  .summary-card.expense .amount { color: var(--red); }
  .summary-card.balance .amount { color: var(--accent); }
  .summary-card .sub { font-size: 0.78rem; color: var(--muted); margin-top: 4px; }

  /* Main Grid */
  .main-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 20px; margin-bottom: 28px; }

  .panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px;
  }
  .panel h2 { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 16px; }

  /* Form */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .form-group { display: flex; flex-direction: column; gap: 5px; }
  .form-group label { font-size: 0.75rem; color: var(--muted); letter-spacing: 0.04em; }
  .form-group input, .form-group select {
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text); padding: 9px 12px; border-radius: 10px; font-size: 0.9rem;
    font-family: 'DM Sans', sans-serif; outline: none; width: 100%;
    transition: border-color 0.2s;
  }
  .form-group input:focus, .form-group select:focus { border-color: var(--accent); }
  .form-group select option { background: #1e1e2e; }

  .type-toggle { display: flex; gap: 8px; margin-bottom: 10px; }
  .type-btn {
    flex: 1; padding: 9px; border: 1.5px solid var(--border); border-radius: 10px;
    background: transparent; color: var(--muted); cursor: pointer; font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem; font-weight: 500; transition: all 0.2s;
  }
  .type-btn.income.active { border-color: var(--green); color: var(--green); background: rgba(34,211,163,0.08); }
  .type-btn.expense.active { border-color: var(--red); color: var(--red); background: rgba(244,63,94,0.08); }

  .add-btn {
    width: 100%; padding: 11px; background: var(--accent); border: none; border-radius: 10px;
    color: white; font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 700;
    cursor: pointer; margin-top: 6px; transition: opacity 0.2s;
  }
  .add-btn:hover { opacity: 0.88; }

  /* Charts */
  .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  canvas { max-height: 180px; }

  /* Transactions */
  .transactions-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .transactions-panel h2 { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 4px; }

  .filter-bar { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; align-items: center; }
  .filter-bar select {
    background: var(--surface2); border: 1px solid var(--border); color: var(--text);
    padding: 6px 10px; border-radius: 8px; font-size: 0.8rem; font-family: 'DM Sans', sans-serif; outline: none;
  }
  .filter-bar input {
    background: var(--surface2); border: 1px solid var(--border); color: var(--text);
    padding: 6px 10px; border-radius: 8px; font-size: 0.8rem; font-family: 'DM Sans', sans-serif; outline: none; flex: 1;
  }

  .tx-list { display: flex; flex-direction: column; gap: 8px; max-height: 320px; overflow-y: auto; }
  .tx-list::-webkit-scrollbar { width: 4px; }
  .tx-list::-webkit-scrollbar-track { background: var(--surface2); }
  .tx-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .tx-item {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--surface2); border-radius: 10px; padding: 11px 14px;
    border: 1px solid var(--border); transition: border-color 0.2s;
  }
  .tx-item:hover { border-color: var(--accent); }
  .tx-left { display: flex; align-items: center; gap: 12px; }
  .tx-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; font-size: 1rem;
  }
  .tx-icon.income { background: rgba(34,211,163,0.15); }
  .tx-icon.expense { background: rgba(244,63,94,0.15); }
  .tx-name { font-size: 0.88rem; font-weight: 500; }
  .tx-cat { font-size: 0.72rem; color: var(--muted); margin-top: 2px; }
  .tx-right { text-align: right; }
  .tx-amount { font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 700; }
  .tx-amount.income { color: var(--green); }
  .tx-amount.expense { color: var(--red); }
  .tx-date { font-size: 0.72rem; color: var(--muted); }
  .tx-delete {
    background: none; border: none; color: var(--muted); cursor: pointer; margin-left: 10px;
    font-size: 1rem; transition: color 0.2s;
  }
  .tx-delete:hover { color: var(--red); }

  .empty-state { text-align: center; color: var(--muted); padding: 30px; font-size: 0.9rem; }

  /* Goals */
  .goals-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; margin-top: 20px; }
  .goals-panel h2 { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 14px; }
  .goals-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .goal-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 14px; }
  .goal-name { font-size: 0.82rem; font-weight: 600; margin-bottom: 6px; }
  .goal-bar-bg { background: var(--border); border-radius: 4px; height: 6px; margin: 8px 0; }
  .goal-bar { background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 4px; height: 6px; transition: width 0.5s; }
  .goal-meta { display: flex; justify-content: space-between; font-size: 0.72rem; color: var(--muted); }

  @media (max-width: 768px) {
    .summary-grid { grid-template-columns: 1fr; }
    .main-grid { grid-template-columns: 1fr; }
    .goals-grid { grid-template-columns: 1fr; }
    .charts-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<header>
  <h1>Budget<span>Flow</span></h1>
  <div class="month-badge" id="currentMonth"></div>
</header>

<div class="container">
  <!-- Summary -->
  <div class="summary-grid">
    <div class="summary-card income">
      <div class="label">Total Income</div>
      <div class="amount" id="totalIncome">₹0</div>
      <div class="sub" id="incomeCount">0 transactions</div>
    </div>
    <div class="summary-card expense">
      <div class="label">Total Expenses</div>
      <div class="amount" id="totalExpense">₹0</div>
      <div class="sub" id="expenseCount">0 transactions</div>
    </div>
    <div class="summary-card balance">
      <div class="label">Net Balance</div>
      <div class="amount" id="netBalance">₹0</div>
      <div class="sub" id="savingsRate">0% savings rate</div>
    </div>
  </div>

  <!-- Form + Charts -->
  <div class="main-grid">
    <div class="panel">
      <h2>➕ Add Transaction</h2>
      <div class="type-toggle">
        <button class="type-btn income active" id="incomeBtn" onclick="setType('income')">📈 Income</button>
        <button class="type-btn expense" id="expenseBtn" onclick="setType('expense')">📉 Expense</button>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Description</label>
          <input type="text" id="desc" placeholder="e.g. Freelance work">
        </div>
        <div class="form-group">
          <label>Amount (₹)</label>
          <input type="number" id="amount" placeholder="0.00" min="0">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Category</label>
          <select id="category">
            <option value="Food">🍔 Food</option>
            <option value="Transport">🚗 Transport</option>
            <option value="Shopping">🛍️ Shopping</option>
            <option value="Rent">🏠 Rent</option>
            <option value="Health">💊 Health</option>
            <option value="Entertainment">🎮 Entertainment</option>
            <option value="Education">📚 Education</option>
            <option value="Salary">💼 Salary</option>
            <option value="Freelance">💻 Freelance</option>
            <option value="Other">📦 Other</option>
          </select>
        </div>
        <div class="form-group">
          <label>Date</label>
          <input type="date" id="txDate">
        </div>
      </div>
      <button class="add-btn" onclick="addTransaction()">Add Transaction</button>
    </div>

    <div class="panel">
      <h2>📊 Analytics</h2>
      <div class="charts-grid">
        <div>
          <div style="font-size:0.72rem;color:var(--muted);margin-bottom:6px;">BY CATEGORY</div>
          <canvas id="pieChart"></canvas>
        </div>
        <div>
          <div style="font-size:0.72rem;color:var(--muted);margin-bottom:6px;">MONTHLY TREND</div>
          <canvas id="barChart"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Transactions -->
  <div class="transactions-panel">
    <h2>📋 Transaction History</h2>
    <div class="filter-bar">
      <input type="text" id="searchInput" placeholder="🔍 Search transactions..." oninput="renderTransactions()">
      <select id="filterCat" onchange="renderTransactions()">
        <option value="">All Categories</option>
        <option>Food</option><option>Transport</option><option>Shopping</option>
        <option>Rent</option><option>Health</option><option>Entertainment</option>
        <option>Education</option><option>Salary</option><option>Freelance</option><option>Other</option>
      </select>
      <select id="filterType" onchange="renderTransactions()">
        <option value="">All Types</option>
        <option value="income">Income</option>
        <option value="expense">Expense</option>
      </select>
    </div>
    <div class="tx-list" id="txList"></div>
  </div>

  <!-- Savings Goals -->
  <div class="goals-panel">
    <h2>🎯 Savings Goals</h2>
    <div class="goals-grid" id="goalsGrid"></div>
  </div>
</div>

<script>
let transactions = JSON.parse(localStorage.getItem('bf_transactions') || '[]');
let selectedType = 'income';

const goals = [
  { name: 'Emergency Fund', target: 50000, icon: '🛡️' },
  { name: 'New Laptop', target: 80000, icon: '💻' },
  { name: 'Vacation', target: 30000, icon: '✈️' },
];

// Seed demo data if empty
if (transactions.length === 0) {
  const today = new Date();
  const m = String(today.getMonth()+1).padStart(2,'0');
  const y = today.getFullYear();
  transactions = [
    { id:1, desc:'Monthly Salary', amount:45000, type:'income', category:'Salary', date:`${y}-${m}-01` },
    { id:2, desc:'Freelance Project', amount:12000, type:'income', category:'Freelance', date:`${y}-${m}-05` },
    { id:3, desc:'Apartment Rent', amount:12000, type:'expense', category:'Rent', date:`${y}-${m}-02` },
    { id:4, desc:'Grocery Shopping', amount:3200, type:'expense', category:'Food', date:`${y}-${m}-08` },
    { id:5, desc:'Uber Rides', amount:1500, type:'expense', category:'Transport', date:`${y}-${m}-10` },
    { id:6, desc:'Netflix + Spotify', amount:800, type:'expense', category:'Entertainment', date:`${y}-${m}-12` },
    { id:7, desc:'Course Purchase', amount:2499, type:'expense', category:'Education', date:`${y}-${m}-15` },
    { id:8, desc:'Medical Checkup', amount:600, type:'expense', category:'Health', date:`${y}-${m}-18` },
  ];
  save();
}

function save() { localStorage.setItem('bf_transactions', JSON.stringify(transactions)); }

function setType(t) {
  selectedType = t;
  document.getElementById('incomeBtn').classList.toggle('active', t==='income');
  document.getElementById('expenseBtn').classList.toggle('active', t==='expense');
}

function addTransaction() {
  const desc = document.getElementById('desc').value.trim();
  const amount = parseFloat(document.getElementById('amount').value);
  const category = document.getElementById('category').value;
  const date = document.getElementById('txDate').value || new Date().toISOString().split('T')[0];
  if (!desc || !amount || amount <= 0) { alert('Please fill in description and amount.'); return; }
  transactions.unshift({ id: Date.now(), desc, amount, type: selectedType, category, date });
  save();
  document.getElementById('desc').value = '';
  document.getElementById('amount').value = '';
  render();
}

function deleteTransaction(id) {
  transactions = transactions.filter(t => t.id !== id);
  save(); render();
}

const catIcons = { Food:'🍔',Transport:'🚗',Shopping:'🛍️',Rent:'🏠',Health:'💊',Entertainment:'🎮',Education:'📚',Salary:'💼',Freelance:'💻',Other:'📦' };

function fmt(n) { return '₹' + n.toLocaleString('en-IN'); }

function renderSummary() {
  const inc = transactions.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const exp = transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const net = inc - exp;
  document.getElementById('totalIncome').textContent = fmt(inc);
  document.getElementById('totalExpense').textContent = fmt(exp);
  document.getElementById('netBalance').textContent = fmt(net);
  document.getElementById('incomeCount').textContent = transactions.filter(t=>t.type==='income').length + ' transactions';
  document.getElementById('expenseCount').textContent = transactions.filter(t=>t.type==='expense').length + ' transactions';
  document.getElementById('savingsRate').textContent = inc > 0 ? Math.round((net/inc)*100)+'% savings rate' : '0% savings rate';
}

function renderTransactions() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const cat = document.getElementById('filterCat').value;
  const type = document.getElementById('filterType').value;
  let filtered = transactions.filter(t => {
    return (!search || t.desc.toLowerCase().includes(search) || t.category.toLowerCase().includes(search))
      && (!cat || t.category === cat)
      && (!type || t.type === type);
  });
  const list = document.getElementById('txList');
  if (filtered.length === 0) { list.innerHTML = '<div class="empty-state">No transactions found.</div>'; return; }
  list.innerHTML = filtered.map(t => `
    <div class="tx-item">
      <div class="tx-left">
        <div class="tx-icon ${t.type}">${catIcons[t.category]||'📦'}</div>
        <div>
          <div class="tx-name">${t.desc}</div>
          <div class="tx-cat">${t.category} · ${t.date}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center">
        <div class="tx-right">
          <div class="tx-amount ${t.type}">${t.type==='income'?'+':'−'}${fmt(t.amount)}</div>
        </div>
        <button class="tx-delete" onclick="deleteTransaction(${t.id})">✕</button>
      </div>
    </div>`).join('');
}

let pieChartInst, barChartInst;

function renderCharts() {
  const expenses = transactions.filter(t=>t.type==='expense');
  const catMap = {};
  expenses.forEach(t => catMap[t.category] = (catMap[t.category]||0)+t.amount);
  const labels = Object.keys(catMap);
  const data = Object.values(catMap);
  const palette = ['#7c6af7','#f97316','#22d3a3','#f43f5e','#3b82f6','#eab308','#ec4899','#14b8a6','#8b5cf6','#84cc16'];

  if (pieChartInst) pieChartInst.destroy();
  pieChartInst = new Chart(document.getElementById('pieChart'), {
    type: 'doughnut',
    data: { labels, datasets: [{ data, backgroundColor: palette.slice(0,labels.length), borderWidth: 0, hoverOffset: 4 }] },
    options: { plugins: { legend: { display: false } }, cutout: '65%', responsive: true }
  });

  // Monthly bar - last 4 months
  const monthData = {};
  transactions.forEach(t => {
    const m = t.date.slice(0,7);
    if (!monthData[m]) monthData[m] = {income:0, expense:0};
    monthData[m][t.type] += t.amount;
  });
  const months = Object.keys(monthData).sort().slice(-4);
  if (barChartInst) barChartInst.destroy();
  barChartInst = new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
      labels: months.map(m => { const d = new Date(m+'-01'); return d.toLocaleString('default',{month:'short'}); }),
      datasets: [
        { label: 'Income', data: months.map(m=>monthData[m]?.income||0), backgroundColor: 'rgba(34,211,163,0.7)', borderRadius: 5 },
        { label: 'Expense', data: months.map(m=>monthData[m]?.expense||0), backgroundColor: 'rgba(244,63,94,0.7)', borderRadius: 5 },
      ]
    },
    options: {
      responsive: true,
      plugins: { legend: { labels: { color: '#8888aa', font: { size: 9 } } } },
      scales: {
        x: { ticks: { color: '#8888aa', font:{size:9} }, grid: { color: '#2e2e3d' } },
        y: { ticks: { color: '#8888aa', font:{size:9} }, grid: { color: '#2e2e3d' } }
      }
    }
  });
}

function renderGoals() {
  const savings = transactions.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0)
                - transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const perGoal = Math.max(0, savings / goals.length);
  document.getElementById('goalsGrid').innerHTML = goals.map(g => {
    const pct = Math.min(100, Math.round((perGoal/g.target)*100));
    return `<div class="goal-card">
      <div class="goal-name">${g.icon} ${g.name}</div>
      <div class="goal-bar-bg"><div class="goal-bar" style="width:${pct}%"></div></div>
      <div class="goal-meta"><span>${fmt(Math.round(perGoal))} saved</span><span>${pct}%</span></div>
      <div style="font-size:0.7rem;color:var(--muted);margin-top:4px;">Target: ${fmt(g.target)}</div>
    </div>`;
  }).join('');
}

function render() {
  renderSummary();
  renderTransactions();
  renderCharts();
  renderGoals();
}

// Init
document.getElementById('txDate').value = new Date().toISOString().split('T')[0];
document.getElementById('currentMonth').textContent = new Date().toLocaleString('default',{month:'long',year:'numeric'});
render();
</script>
</body>
</html>
